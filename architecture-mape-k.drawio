        <mxCell id="a-e6" edge="1" parent="1" source="a-compl" target="a-emissor" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0;exitY=0.5;entryX=1;entryY=0.7;endArrow=classic;strokeColor=#6D28D9;fontSize=10;fontColor=#6D28D9;" value="vitrine completa">

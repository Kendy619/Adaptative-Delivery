        <mxCell id="x-ext-kb" parent="1" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#B45309;fontSize=10;boundedLbl=1;backgroundOutline=1;size=12;" value="Base de Conhecimento&#xa;tipos das ações (AdaptiveResponse, CategoryRecommendation, CrossSellItem) · estado React da sessão" vertex="1">
          <mxGeometry x="580" y="660" width="320" height="100" as="geometry" />
        </mxCell>
        <mxCell id="x-e1" edge="1" parent="1" source="x-ext-plan" target="x-recep" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0;exitY=0.5;entryX=1;entryY=0.5;endArrow=classic;strokeColor=#047857;strokeWidth=2;fontSize=10;fontColor=#047857;" value="plano">

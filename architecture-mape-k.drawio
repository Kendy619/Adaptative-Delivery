        </mxCell>
        <mxCell id="x-ext-plan" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#374151;strokeWidth=2;fontSize=12;fontStyle=1;" value="Planejador&#xa;(emite o plano)" vertex="1">

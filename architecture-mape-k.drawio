        <mxCell id="p-map-frame" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FAFB;strokeColor=#9CA3AF;fontSize=12;fontStyle=1;verticalAlign=top;align=left;spacingLeft=12;spacingTop=8;" value="Mapeamento subcomponente → código do Adaptive Delivery" vertex="1">
